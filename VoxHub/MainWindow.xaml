<Window x:Class="VoxHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VoxHub"
        mc:Ignorable="d"
        Title="VoxHub Client"
        Width="1400"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">
    
    <!-- Resources -->
    <Window.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Models list -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                CornerRadius="12"
                Background="#151B23"
                BorderBrush="#3D444D"
                BorderThickness="1"
                Padding="15"
                Margin="0, 0, 0, 15">
                <StackPanel>
                    <TextBlock Text="All models"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#F0F6FC"
                               HorizontalAlignment="Center"
                               Margin="0, 0, 0, 15" />

                    <ListBox ItemsSource="{Binding Models}"
                             SelectedItem="{Binding SelectedModel}"
                             Background="Transparent"
                             BorderBrush="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#F0F6FC"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border
                Grid.Row="1"
                CornerRadius="12"
                Background="#151B23"
                BorderBrush="#3D444D"
                BorderThickness="1"
                Padding="15">
                <StackPanel>
                    <TextBlock Text="Model name"
                               FontSize="12"
                               Foreground="#9198A1" />

                    <Border CornerRadius="12"
                            Background="#0D1117"
                            BorderBrush="#3D444D"
                            BorderThickness="1"
                            Margin="0, 15">
                        <TextBox x:Name="ModelNameBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#F0F6FC"
                                 Height="44"
                                 FontSize="16"
                                 Padding="10, 0"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="#F0F6FC" />
                    </Border>

                    <Button Content="Upload model"
                            Height="44"
                            FontSize="16"
                            Background="#1F71EB"
                            BorderThickness="0"
                            Foreground="#F0F6FC"
                            FontWeight="SemiBold"
                            Click="UploadSnapshot_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- CENTER PANEL: Graph + 3D Viewport -->
        <Grid Grid.Column="1" Margin="15, 0, 15, 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="220" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Version Graph -->
            <Border Grid.Row="0"
                    CornerRadius="12"
                    Background="#151B23"
                    BorderBrush="#3D444D"
                    BorderThickness="1"
                    Padding="15"
                    Margin="0, 0, 0, 15">
                <local:VersionGraphControl x:Name="VersionGraph" />
            </Border>

            <!-- 3D Viewports Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="0" x:Name="SecondaryColumnDefinition" />
                </Grid.ColumnDefinitions>

                <!-- Primary Viewport -->
                <Border Grid.Column="0"
                        CornerRadius="12"
                        Background="#151B23"
                        BorderBrush="#3D444D"
                        BorderThickness="1"
                        Padding="15"
                        Margin="0, 0, 0, 0"
                        x:Name="PrimaryViewportBorder">
                    <Viewport3D x:Name="Viewport"
                                MouseDown="Viewport_MouseDown"
                                MouseMove="Viewport_MouseMove"
                                MouseUp="Viewport_MouseUp"
                                MouseWheel="Viewport_MouseWheel">
                        <Viewport3D.Camera>
                            <PerspectiveCamera x:Name="Camera"
                                               Position="0,0,120"
                                               LookDirection="0,0,-120"
                                               UpDirection="0,1,0"
                                               FieldOfView="60" />
                        </Viewport3D.Camera>
                    </Viewport3D>
                </Border>

                <!-- Secondary Viewport (hidden by default) -->
                <Border Grid.Column="1"
                        x:Name="SecondaryViewportBorder"
                        CornerRadius="12"
                        Background="#151B23"
                        BorderBrush="#3D444D"
                        BorderThickness="1"
                        Padding="15"
                        Margin="7.5, 0, 0, 0"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Sync Buttons -->
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0, 0, 0, 10">
                            <Button Content="🔗 Sync View"
                                    Height="28"
                                    Background="#238636"
                                    BorderThickness="0"
                                    Foreground="#F0F6FC"
                                    FontWeight="SemiBold"
                                    FontSize="11"
                                    Margin="0, 0, 8, 0"
                                    Click="SyncSecondaryToFirst_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="🔗 Sync Back"
                                    Height="28"
                                    Background="#238636"
                                    BorderThickness="0"
                                    Foreground="#F0F6FC"
                                    FontWeight="SemiBold"
                                    FontSize="11"
                                    Click="SyncFirstToSecondary_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="❌ Close"
                                    Height="28"
                                    Background="#DA3633"
                                    BorderThickness="0"
                                    Foreground="#F0F6FC"
                                    FontWeight="SemiBold"
                                    FontSize="11"
                                    Margin="15, 0, 0, 0"
                                    Click="CloseSecondaryViewport_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <!-- Color picker + Opacity + ShowDiff -->
                            <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                                <ComboBox x:Name="DiffColorBox" Width="110" Height="28" Margin="0,0,8,0">
                                    <ComboBoxItem Content="Red" Tag="#FFEA4C4C" IsSelected="False" />
                                    <ComboBoxItem Content="Green" Tag="#FF58D68D" />
                                    <ComboBoxItem Content="Cyan" Tag="#FF4DD0E1" />
                                    <ComboBoxItem Content="Yellow" Tag="#FFF6E05E" />
                                    <ComboBoxItem Content="Magenta" Tag="#FFE070C8" />
                                    <ComboBoxItem Content="Orange" Tag="#FFF2994A" />
                                </ComboBox>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="Opacity" Foreground="#9AA4AD" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <Slider x:Name="DiffOpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.65" Width="110" Height="24" />
                                </StackPanel>

                                <Button x:Name="ShowDiffButton"
                                        Content="🔍 Show Diff"
                                        Height="28"
                                        Background="#1F71EB"
                                        Foreground="White"
                                        Click="ShowDiffButton_Click"
                                        Margin="0,0,6,0" />

                                <Button x:Name="HideDiffButton"
                                        Content="✖ Hide Diff"
                                        Height="28"
                                        Background="#DA3633"
                                        Foreground="White"
                                        Click="HideDiffButton_Click"
                                        Visibility="Collapsed" />
                            </StackPanel>
                        </StackPanel>

                        <Viewport3D Grid.Row="1"
                                    x:Name="SecondaryViewport"
                                    MouseDown="SecondaryViewport_MouseDown"
                                    MouseMove="SecondaryViewport_MouseMove"
                                    MouseUp="SecondaryViewport_MouseUp"
                                    MouseWheel="SecondaryViewport_MouseWheel">
                            <Viewport3D.Camera>
                                <PerspectiveCamera x:Name="SecondaryCamera"
                                                   Position="0,0,120"
                                                   LookDirection="0,0,-120"
                                                   UpDirection="0,1,0"
                                                   FieldOfView="60" />
                            </Viewport3D.Camera>
                        </Viewport3D>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <!-- RIGHT PANEL: Version actions + Commit -->
        <Border Grid.Column="2"
                CornerRadius="12"
                Background="#151B23"
                BorderBrush="#3D444D"
                BorderThickness="1"
                Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Selected Version Info -->
                    <TextBlock Text="Selected Version"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#F0F6FC"
                               HorizontalAlignment="Center"
                               Margin="0, 0, 0, 10" />

                    <TextBlock Text="{Binding SelectedVersion.Display, StringFormat='{}{0}'}"
                               Foreground="#9198A1"
                               HorizontalAlignment="Center"
                               FontSize="11"
                               Margin="0, 0, 0, 15"
                               TextWrapping="Wrap" />

                    <!-- Commit Info Card -->
                    <Border CornerRadius="8"
                            Background="#0D1117"
                            BorderBrush="#3D444D"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0, 0, 0, 15"
                            Visibility="{Binding SelectedVersion.CommitInfo, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="📝 Commit Info"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#58A6FF"
                                       Margin="0, 0, 0, 8" />

                            <TextBlock Text="Message:"
                                       FontSize="10"
                                       Foreground="#7A8390"
                                       Margin="0, 0, 0, 3" />

                            <TextBlock Text="{Binding SelectedVersion.CommitInfo.Message}"
                                       FontSize="11"
                                       Foreground="#F0F6FC"
                                       TextWrapping="Wrap"
                                       Margin="0, 0, 0, 8" />

                            <TextBlock Text="Created:"
                                       FontSize="10"
                                       Foreground="#7A8390"
                                       Margin="0, 0, 0, 3" />

                            <TextBlock Text="{Binding SelectedVersion.CommitInfo.CreatedAt, StringFormat='{}{0:g}'}"
                                       FontSize="10"
                                       Foreground="#8B949E"
                                       Margin="0, 0, 0, 0" />
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <Button Content="⬇ Download"
                            Height="40"
                            Background="#238636"
                            BorderThickness="0"
                            Foreground="#F0F6FC"
                            FontWeight="SemiBold"
                            FontSize="14"
                            Margin="0, 0, 0, 15"
                            Click="DownloadFromGraph_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Divider -->
                    <Separator Background="#3D444D" Margin="0, 0, 0, 15" />

                    <!-- Commit Section -->
                    <TextBlock Text="Create Commit"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#F0F6FC"
                               HorizontalAlignment="Center"
                               Margin="0, 0, 0, 10" />

                    <!-- Commit Message Input -->
                    <TextBlock Text="Commit Message"
                               FontSize="12"
                               Foreground="#9198A1"
                               Margin="0, 0, 0, 6" />

                    <Border CornerRadius="12"
                            Background="#0D1117"
                            BorderBrush="#3D444D"
                            BorderThickness="1"
                            Margin="0, 0, 0, 10">
                        <TextBox x:Name="CommitMessageBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#F0F6FC"
                                 AcceptsReturn="True"
                                 Height="60"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="10"
                                 CaretBrush="#F0F6FC"
                                 Text="Updated model" />
                    </Border>

                    <Button Content="⬆ Confirm Commit"
                            Height="40"
                            Background="#1F71EB"
                            BorderThickness="0"
                            Foreground="#F0F6FC"
                            FontWeight="SemiBold"
                            FontSize="14"
                            Click="CreateCommit_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock x:Name="UploadStatusText"
                               Text=""
                               Foreground="#16C60C"
                               Margin="0, 12, 0, 0"
                               TextWrapping="Wrap"
                               FontSize="11" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>