<Window x:Class="VoxHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VoxHub"
        mc:Ignorable="d"
        Title="VoxHub Client"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="0,0,1,0"
                Padding="12">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock Text="Models / Versions"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />

                    <!-- Upload Snapshot Section -->
                    <TextBlock Text="Upload Snapshot"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBlock Text="Model name" />
                    <TextBox x:Name="ModelNameBox" Text="test-model" Margin="0,4,0,6" />

                    <TextBlock Text="Chunk size" />
                    <TextBox x:Name="ChunkSizeBox" Text="16" Margin="0,4,0,12" />
                    <Button Content="Upload snapshot"
                            Height="32"
                            Margin="0,0,0,16"
                            Click="UploadSnapshot_Click" />

                    <!-- Models Section -->
                    <TextBlock Text="Models" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <ListBox Height="200"
                             ItemsSource="{Binding Models}"
                             SelectedItem="{Binding SelectedModel}"
                             DisplayMemberPath="Name"
                             Margin="0,0,0,12" />

                    <!-- Versions Section -->
                    <TextBlock Text="Versions" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <ListBox Height="150"
                             ItemsSource="{Binding Versions}"
                             SelectedItem="{Binding SelectedVersion}"
                             DisplayMemberPath="Display"
                             Margin="0,0,0,12" />

                    <!-- Create Commit Section -->
                    <TextBlock Text="Create Commit"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBlock Text="Commit message" />
                    <TextBox x:Name="CommitMessageBox"
                             Text="Updated model"
                             Margin="0,4,0,12"
                             AcceptsReturn="True"
                             Height="60" />

                    <Button x:Name="CreateCommitButton"
                            Content="Create commit"
                            Height="32"
                            Margin="0,0,0,12"
                            Click="CreateCommit_Click" />
                    
                    <TextBlock x:Name="UploadStatusText"
                               Text=""
                               Foreground="Green"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right panel -->
        <Grid Grid.Column="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Download .vox"
                        Width="140"
                        Height="32"
                        Click="Download_Click" />
            </StackPanel>

            <Viewport3D x:Name="Viewport"
                        Grid.Row="1"
                        MouseDown="Viewport_MouseDown"
                        MouseMove="Viewport_MouseMove"
                        MouseUp="Viewport_MouseUp"
                        MouseWheel="Viewport_MouseWheel">
                <Viewport3D.Camera>
                    <PerspectiveCamera x:Name="Camera"
                                       Position="0,0,120"
                                       LookDirection="0,0,-120"
                                       UpDirection="0,1,0"
                                       FieldOfView="60" />
                </Viewport3D.Camera>
            </Viewport3D>
        </Grid>
    </Grid>
</Window>